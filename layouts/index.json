{{- $pages := where .Site.RegularPages "Title" "ne" "" -}}
{{- $result := slice -}}
{{- range $pages -}}
  {{- $item := dict "title" .Title "permalink" .Permalink "section" .Section "date" (.Date.Format "2006-01-02") -}}
  {{- $result = $result | append $item -}}
{{- end -}}
{{- $result | jsonify -}}
